# ============================================================
# ChatUI — Local-to-Cloud AI Gateway
# Copy this file to .env and fill in your values.
# ============================================================

# ── General ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_AUTHOR=Debojyoti Das
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── Backend ──────────────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_INTERNAL_URL=http://backend:8000
DATABASE_URL=sqlite:///./data/chatui.db

# ── Ollama ───────────────────────────────────────────────────
# On macOS, Ollama must be started with network access enabled:
#   OLLAMA_HOST=0.0.0.0 OLLAMA_ORIGINS="*" ollama serve
# Note: launchctl setenv does NOT apply to an already-running process.
# host.docker.internal works on Mac/Windows Docker Desktop.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Cloud API Keys (stored in DB via Settings UI, NOT here) ──
# These are optional bootstrap values. Prefer the Settings UI.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# ── MCP Servers (comma-separated JSON endpoints) ────────────
# MCP_SERVER_URLS=https://mcp.example.com/.well-known/mcp.json

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_PORT=3000
